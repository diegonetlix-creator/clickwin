{
  "name": "Task",
  "type": "object",
  "properties": {
    "campaign_id": { "type": "string", "description": "Reference to Campaign" },
    "campaign_title": { "type": "string", "description": "Campaign title (denormalized)" },
    "social_network": { "type": "string", "description": "Social network" },
    "task_type": { "type": "string", "description": "Type of task" },
    "target_url": { "type": "string", "description": "URL to perform action on" },
    "instructions": { "type": "string", "description": "Task instructions" },
    "reference_image_url": { "type": "string", "description": "Reference image" },
    "reward": { "type": "number", "description": "Reward for completing this task" },
    "worker_id": { "type": "string", "description": "Worker who claimed this task" },
    "worker_email": { "type": "string", "description": "Worker email" },
    "worker_name": { "type": "string", "description": "Worker name" },
    "promoter_id": { "type": "string", "description": "Promoter who owns this task" },
    "promoter_email": { "type": "string", "description": "Promoter email" },
    "status": {
      "type": "string",
      "enum": ["available", "claimed", "submitted", "approved", "rejected", "expired"],
      "default": "available",
      "description": "Task status"
    },
    "evidence_url": { "type": "string", "description": "Screenshot/evidence URL" },
    "evidence_note": { "type": "string", "description": "Worker's note with evidence" },
    "rejection_reason": { "type": "string", "description": "Reason for rejection" },
    "claimed_at": { "type": "string", "description": "When task was claimed" },
    "submitted_at": { "type": "string", "description": "When evidence was submitted" },
    "reviewed_at": { "type": "string", "description": "When task was reviewed" },
    "time_limit_hours": { "type": "number", "default": 24, "description": "Hours to complete after claiming" },
    "is_daily_mission": { "type": "boolean", "default": false, "description": "Is this a daily mission" }
  },
  "required": ["campaign_id", "task_type", "reward"]
}