{
  "name": "WorkerProfile",
  "type": "object",
  "properties": {
    "user_id": { "type": "string", "description": "Reference to User" },
    "user_email": { "type": "string", "description": "User email" },
    "display_name": { "type": "string", "description": "Display name" },
    "avatar_url": { "type": "string", "description": "Avatar image URL" },
    "country": { "type": "string", "description": "Country" },
    "bio": { "type": "string", "description": "Short bio" },
    "total_points": { "type": "number", "default": 0, "description": "Total points earned" },
    "available_balance": { "type": "number", "default": 0, "description": "Available balance to withdraw" },
    "total_withdrawn": { "type": "number", "default": 0, "description": "Total withdrawn" },
    "tasks_completed": { "type": "number", "default": 0, "description": "Total tasks completed" },
    "tasks_approved": { "type": "number", "default": 0, "description": "Tasks approved" },
    "tasks_rejected": { "type": "number", "default": 0, "description": "Tasks rejected" },
    "current_streak": { "type": "number", "default": 0, "description": "Current daily streak" },
    "max_streak": { "type": "number", "default": 0, "description": "Maximum streak achieved" },
    "level": { "type": "number", "default": 1, "description": "User level" },
    "xp": { "type": "number", "default": 0, "description": "Experience points" },
    "rank_position": { "type": "number", "description": "Global rank position" },
    "weekly_points": { "type": "number", "default": 0, "description": "Points this week" },
    "referral_code": { "type": "string", "description": "Unique referral code" },
    "referred_by": { "type": "string", "description": "Referral code used to sign up" },
    "referral_count": { "type": "number", "default": 0, "description": "Number of referrals" },
    "is_verified": { "type": "boolean", "default": false },
    "is_suspended": { "type": "boolean", "default": false },
    "suspension_reason": { "type": "string" },
    "last_active": { "type": "string", "description": "Last activity timestamp" },
    "daily_missions_completed": { "type": "number", "default": 0 },
    "badges": { "type": "array", "items": { "type": "string" }, "description": "Earned badges" }
  },
  "required": ["user_id", "user_email"]
}